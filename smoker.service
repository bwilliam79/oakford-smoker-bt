[Unit]
Description=Oakford Smoker Monitor
After=bluetooth.target network-online.target
Wants=bluetooth.target network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/oakford-smoker-bt
ExecStart=/home/pi/oakford-smoker-bt/venv/bin/python3 server.py --interval 30 --port 8080
Restart=on-failure
RestartSec=15
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
